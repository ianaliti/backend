const token = "PASTE_RESTAURANT_JWT_HERE";
const ws = new WebSocket("ws://127.0.0.1:3000/ws/restaurant");
ws.onopen = () => {
  console.log("WS opened");
  ws.send(JSON.stringify({ event: "authenticate", token }));
};
